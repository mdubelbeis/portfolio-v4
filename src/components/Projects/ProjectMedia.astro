---
import { Image } from 'astro:assets';
import bugBoard from '../../assets/imgs/bug-board-wb.png';
import clienthub from '../../assets/imgs/clienthub.png';
import dubex from '../../assets/imgs/dubex-wb.png';
import orderMgmt from '../../assets/imgs/order-management-api.png';
import vacations from '../../assets/imgs/vacations-api.png';

type ProjectName =
  | 'Bug-Board'
  | 'ClientHub'
  | 'Dubex'
  | 'Order Management API'
  | 'Vacations API';

interface Props {
  projectName: ProjectName;
}
const { projectName } = Astro.props;

const projectImages: Record<ProjectName, ImageMetadata> = {
  'Bug-Board': bugBoard,
  ClientHub: clienthub,
  Dubex: dubex,
  'Order Management API': orderMgmt,
  'Vacations API': vacations,
};

const projectImage = projectImages[projectName];
---

{
  projectImage ? (
    <Image
      class='project-media'
      src={projectImage}
      alt={`${projectName} project preview`}
      loading='lazy'
      decoding='async'
    />
  ) : (
    <div class='project-media project-media-empty'>
      <p>No preview available</p>
    </div>
  )
}

<style>
  .project-media {
    width: 100%;
    height: 20rem;
    overflow: hidden;
    border-radius: 0.5rem 0.5rem 0 0;
  }

  img.project-media {
    display: block;
    object-fit: contain;
  }
</style>
