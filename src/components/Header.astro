---
import { getCollection } from 'astro:content';

const socials = await getCollection('socials');
---

<header class='site-header'>
  <div class='header-container'>
    <a href='#top' class='brand-link' aria-label='Go to top of page'>
      <span class='brand-mark'>MD</span>

      <div class='brand-text'>
        <p class='brand-name'>Mason Dubelbeis</p>
        <p class='brand-title'>Software Engineer</p>
      </div>
    </a>

    <nav aria-label='Social links'>
      <ul class='social-list'>
        {
          socials.map((link) => (
            <li>
              <a
                href={link.data.url}
                target={
                  link.data.url.startsWith('mailto:') ? undefined : '_blank'
                }
                rel={
                  link.data.url.startsWith('mailto:')
                    ? undefined
                    : 'noopener noreferrer'
                }
                aria-label={link.data.label}
                class='social-link'
              >
                {link.data.icon}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    z-index: 50;
    width: 100%;
    border-bottom: 1px solid rgba(226, 232, 240, 0.8);
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(12px);
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 80rem;
    margin-inline: auto;
    padding: 1rem 1.5rem;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .brand-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.75rem;
    background: #1d4ed8;
    color: #ffffff;
    font-size: 0.875rem;
    font-weight: 700;
    box-shadow: 0 4px 10px rgba(29, 78, 216, 0.2);
  }

  .brand-text {
    display: none;
    line-height: 1.25;
  }

  .brand-name {
    color: #020617;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: -0.025em;
  }

  .brand-title {
    color: #64748b;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .social-list {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    list-style-type: none;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid #e2e8f0;
    border-radius: 0.75rem;
    background: #ffffff;
    color: #334155;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.08);
    text-decoration: none;
  }

  .social-link:hover {
    transform: translateY(-0.125rem);
    border-color: #bfdbfe;
    background: #eff6ff;
    color: #1d4ed8;
    box-shadow: 0 4px 8px rgba(15, 23, 42, 0.12);
  }

  .social-link:focus {
    outline: none;
  }

  .social-link:focus-visible {
    outline: 2px solid #3b82f6;
    outline-offset: 2px;
  }

  @media (min-width: 640px) {
    .brand-text {
      display: block;
    }
  }

  @media (min-width: 1024px) {
    .header-container {
      padding-inline: 3rem;
    }
  }
</style>
